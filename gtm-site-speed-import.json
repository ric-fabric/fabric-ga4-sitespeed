                    {
                        "type": "TEMPLATE",
                        "key": "html",
                        "value": "<script>\n// Fabric Analytics, Performance API to dataLayer for GA4.\n// Reports once per page at teardown (tab hidden / pagehide)\n  \n(function () {\n  var SAMPLE_RATE = 1; // 0-1, e.g. 0.25 measures a quarter of page loads\n\n  if (Math.random() >= SAMPLE_RATE) return;\n  if (!('PerformanceObserver' in window) ||\n      !performance.getEntriesByType ||\n      !performance.getEntriesByType('navigation').length) return;\n\n  var nav = performance.getEntriesByType('navigation')[0];\n\n  // Default buffer is 250 entries - not enough for heavy pages\n  try { performance.setResourceTimingBufferSize(1000); } catch (e) {}\n\n  // Paint metrics are unreliable if the tab loaded in the background\n  var wasHidden = document.visibilityState !== 'visible';\n  var loaded = document.readyState === 'complete';\n  window.addEventListener('load', function () { loaded = true; });\n  document.addEventListener('visibilitychange', function () {\n    if (document.visibilityState === 'hidden' && !loaded) wasHidden = true;\n  });\n\n  var fcp = null;\n  try {\n    new PerformanceObserver(function (list, obs) {\n      var entry = list.getEntriesByName('first-contentful-paint')[0];\n      if (entry) { fcp = Math.round(entry.startTime); obs.disconnect(); }\n    }).observe({ type: 'paint', buffered: true });\n  } catch (e) {}\n\n  var lcp = null, lcpElement = null;\n  try {\n    new PerformanceObserver(function (list) {\n      var entries = list.getEntries();\n      var entry = entries[entries.length - 1];\n      lcp = Math.round(entry.startTime);\n      var el = entry.element;\n      if (el) {\n        var ident = el.tagName;\n        if (el.id) {\n          ident += '#' + el.id;\n        } else if (entry.url) {\n          var file = entry.url.split('?')[0].split('/').pop();\n          if (file) ident += ':' + file;\n        }\n        lcpElement = ident.slice(0, 100);\n      }\n    }).observe({ type: 'largest-contentful-paint', buffered: true });\n  } catch (e) {}\n\n  // score uses the same method as CrUX\n  var cls = 0, clsWindow = 0, clsWindowEntries = [];\n  try {\n    new PerformanceObserver(function (list) {\n      list.getEntries().forEach(function (entry) {\n        if (entry.hadRecentInput) return;\n        var first = clsWindowEntries[0];\n        var last = clsWindowEntries[clsWindowEntries.length - 1];\n        if (clsWindow &&\n            entry.startTime - last.startTime < 1000 &&\n            entry.startTime - first.startTime < 5000) {\n          clsWindow += entry.value;\n          clsWindowEntries.push(entry);\n        } else {\n          clsWindow = entry.value;\n          clsWindowEntries = [entry];\n        }\n        if (clsWindow > cls) cls = clsWindow;\n      });\n    }).observe({ type: 'layout-shift', buffered: true });\n  } catch (e) {}\n\n  // INP: keep the 10 slowest interactions\n  var interactions = [];\n  var minId = Infinity, maxId = 0;\n  function recordInteraction(entry) {\n    if (!entry.interactionId) return;\n    minId = Math.min(minId, entry.interactionId);\n    maxId = Math.max(maxId, entry.interactionId);\n    var existing = null;\n    for (var i = 0; i < interactions.length; i++) {\n      if (interactions[i].id === entry.interactionId) { existing = interactions[i]; break; }\n    }\n    if (existing) existing.latency = Math.max(existing.latency, entry.duration);\n    else interactions.push({ id: entry.interactionId, latency: entry.duration });\n    interactions.sort(function (a, b) { return b.latency - a.latency; });\n    if (interactions.length > 10) interactions.length = 10;\n  }\n  try {\n    new PerformanceObserver(function (list) { list.getEntries().forEach(recordInteraction); })\n      .observe({ type: 'event', buffered: true, durationThreshold: 40 });\n    new PerformanceObserver(function (list) { list.getEntries().forEach(recordInteraction); })\n      .observe({ type: 'first-input', buffered: true });\n  } catch (e) {}\n  function getINP() {\n    if (!interactions.length) return null;\n    var count = (performance.interactionCount !== undefined)\n      ? performance.interactionCount\n      : (maxId ? (maxId - minId) / 7 + 1 : 0);\n    return Math.round(interactions[Math.min(interactions.length - 1, Math.floor(count / 50))].latency);\n  }\n\n  var reported = false;\n  function report() {\n    if (reported) return;\n    reported = true;\n\n    var resources = performance.getEntriesByType('resource');\n    var decodedSize = 0, transferSize = 0, cacheHits = 0, measurable = 0, taoBlocked = 0;\n    resources.forEach(function (r) {\n      var decoded = r.decodedBodySize || 0;\n      var transfer = r.transferSize || 0;\n      decodedSize += decoded;\n      transferSize += transfer;\n      if (decoded === 0 && transfer === 0) {\n        taoBlocked++;\n      } else {\n        measurable++;\n        if (transfer === 0) cacheHits++;\n      }\n    });\n\n    var conn = navigator.connection || {};\n\n    window.dataLayer = window.dataLayer || [];\n    window.dataLayer.push({\n      event: 'site_speed',\n      siteSpeedMeasurement: {\n        ttfb: Math.round(nav.responseStart),\n        fcp: fcp,\n        lcp: lcp,\n        cls: Math.round(cls * 1000) / 1000,\n        inp: getINP(),\n        load: nav.domComplete ? Math.round(nav.domComplete) : null,\n        dcl: nav.domContentLoadedEventEnd ? Math.round(nav.domContentLoadedEventEnd) : null,\n        redirect_time: Math.round(nav.redirectEnd - nav.redirectStart),\n        dns_time: Math.round(nav.domainLookupEnd - nav.domainLookupStart),\n        connect_time: Math.round(nav.connectEnd - nav.connectStart),\n        decoded_size: decodedSize,\n        transfer_size: transferSize,\n        requests: resources.length,\n        tao_blocked: taoBlocked,\n        cache_hit_ratio: measurable ? Math.round(cacheHits / measurable * 100) / 100 : null,\n        lcp_element: lcpElement,\n        connection_type: conn.effectiveType || null,\n        rtt: (conn.rtt !== undefined) ? conn.rtt : null,\n        downlink: (conn.downlink !== undefined) ? conn.downlink : null,\n        nav_type: nav.type,\n        was_hidden: wasHidden\n      }\n    });\n  }\n\n  // Tab hidden is the most reliable end of page signal\n  document.addEventListener('visibilitychange', function () {\n    if (document.visibilityState === 'hidden') report();\n  });\n  window.addEventListener('pagehide', report);\n})();\n</script>"
